{
  "mcpServers": {
    "webflow": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-webflow"],
      "env": {
        "WEBFLOW_API_TOKEN": "${WEBFLOW_API_TOKEN}"
      }
    },
    "cloudflare": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-cloudflare"],
      "env": {
        "CLOUDFLARE_API_TOKEN": "${CLOUDFLARE_API_TOKEN}",
        "CLOUDFLARE_ACCOUNT_ID": "${CLOUDFLARE_ACCOUNT_ID}"
      }
    }
  }
}
