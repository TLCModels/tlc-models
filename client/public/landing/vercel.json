{
  "rewrites": [
    { "source": "/f1", "destination": "/f1.html" },
    { "source": "/fifa", "destination": "/fifa.html" },
    { "source": "/las-vegas", "destination": "/las-vegas.html" },
    { "source": "/", "destination": "/las-vegas.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
